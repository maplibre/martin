#!/usr/bin/env just --justfile

set shell := ['bash', '-c']

dockercompose := `if docker-compose --version &> /dev/null; then echo "docker-compose"; else echo "docker compose"; fi`

@_default:
    just --list

build:
    {{dockercompose}} build

# Build the PMTiles data file locally (requires sufficient RAM).
# Then rsync to prod, for example:
#   rsync -avz tiles/data/output.pmtiles user@host:<repo_root>/demo/tiles/data/
build-data:
    mkdir -p tiles/data
    docker run --rm --user=$UID -d --cpu-shares 512 --pull always \
      --memory="50G" --memory-swap="50G" -e JAVA_TOOL_OPTIONS="-Xmx25g" \
      -v "$(pwd)/tiles/data:/data" \
      ghcr.io/onthegomap/planetiler:latest \
      --download --download-threads=10 --download-chunk-size-mb=1000 \
      --free_natural_earth_after_read=true --free_water_polygons_after_read=true --free_lake_centerlines_after_read=true \
      --languages=en \
      --Xmx25g --nodemap-type=array --storage=mmap \
      --area=oberbayern --bound=oberbayern --force=true \
      --output=/data/output.pmtiles \
      --tile_format=mlt --tile_compression=none \
      --mlt_advanced=true --mlt_fastpfor=true --mlt_fsst=true \
      --mlt_reorder_features=true --mlt_tessellate_polygons=false --mlt_shared_dict=false \
      --exclude_ids=true --skip_filled_tiles=true --transportation_name_brunnel=true \
      "--exclude_layers=building,housenumber,poi,transportation_name,water_name,aerodrome_label,aeroway,mountain_peak,place,park" \
      --min_feature_size=2 --min_feature_size_at_max_zoom=0.25 \
      --simplify_tolerance=0.2 --simplify_tolerance_at_max_zoom=0.125 \
      --max_zoom=13

clean:
    rm -rf frontend/node_modules

frontend *ARGS:
    {{dockercompose}} up frontend {{ARGS}}

[no-exit-message]
frontend-sh:
    {{dockercompose}} run --interactive --entrypoint sh frontend

up:
    {{dockercompose}} up

up-backend:
    {{dockercompose}} up db tiles --detach

up-build:
    {{dockercompose}} up --build
