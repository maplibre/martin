{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "extends": "//",
  "files": {
    "includes": [
      "*.{tsx,ts,mjs,json,jsonc,astro}",
      "{app,components,lib,src}/**/*.{tsx,ts,mjs,json,jsonc,astro}",
      "!node_modules",
      "!dist",
      "!.astro"
    ]
  },
  "html": {
    "experimentalFullSupportEnabled": true
  },
  "linter": {
    "rules": {
      "style": {
        "useComponentExportOnlyModules": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          },
          "style": {
            "useConst": "off",
            "useImportType": "off"
          }
        }
      }
    }
  ]
}
