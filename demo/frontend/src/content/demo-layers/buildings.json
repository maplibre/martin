{
  "allowedParameters": [
    {
      "default": 0,
      "label": "Min height (m)",
      "max": 500,
      "min": 0,
      "name": "min_height",
      "type": "number"
    },
    {
      "default": 300,
      "label": "Max height (m)",
      "max": 500,
      "min": 0,
      "name": "max_height",
      "type": "number"
    },
    {
      "default": "",
      "label": "Type",
      "name": "building_type",
      "options": ["", "residential", "commercial", "industrial", "retail"],
      "type": "string"
    }
  ],
  "id": "buildings",
  "label": "Buildings",
  "layerType": "fill",
  "paint": {
    "fill-color": [
      "interpolate",
      ["linear"],
      ["get", "height"],
      0,
      "#1a2d48",
      50,
      "#5b95e0",
      200,
      "#95BEFA"
    ],
    "fill-opacity": 0.85,
    "fill-outline-color": "#95BEFA"
  },
  "sourceLayer": "buildings",
  "sqlTemplate": "SELECT ST_AsMVT(q, 'buildings', 4096, 'geom')\nFROM (\n  SELECT\n    id, height, type,\n    ST_AsMVTGeom(geom, TileBBox({z},{x},{y})) geom\n  FROM buildings\n  WHERE geom && TileBBox({z},{x},{y})\n    AND height >= {{min_height}} AND height <= {{max_height}}\n    AND ({{building_type}} = '' OR type = {{building_type}})\n) q",
  "url": "/buildings/{z}/{x}/{y}"
}
