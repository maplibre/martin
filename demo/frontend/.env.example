# Optional: GitHub token for higher rate limits when fetching repo stats at build time.
# Without it, the demo still builds and falls back to placeholder stats if the API is rate-limited.
# GITHUB_TOKEN=ghp_...

# Optional: override Martin tile/API base URL (default: https://martin.maplibre.org).
# Only needed when deploying the demo against a different Martin instance.
# PUBLIC_MARTIN_BASE_URL=https://martin.maplibre.org
