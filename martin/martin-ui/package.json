{
  "dependencies": {
    "@maplibre/maplibre-gl-inspect": "1.8.2",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-hover-card": "1.1.19",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-toast": "1.2.19",
    "@radix-ui/react-tooltip": "1.2.12",
    "@tailwindcss/vite": "^4.3.1",
    "@vis.gl/react-maplibre": "8.1.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.23.0",
    "maplibre-gl": "5.24.0",
    "next-themes": "0.4.6",
    "openapi-fetch": "0.17.0",
    "pbf": "^5.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "10.1.0",
    "identity-obj-proxy": "3.0.0",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "ts-node": "10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  },
  "name": "martin-ui",
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  },
  "private": true,
  "scripts": {
    "build": "cross-env VITE_MARTIN_VERSION=$npm_package_version vite build",
    "dev": "vite --port 3001",
    "format": "biome check --write",
    "gen-types": "openapi-typescript ../../schemas/openapi.json --output src/lib/types.gen.ts --root-types --root-types-no-schema-prefix --default-non-nullable=false",
    "lint": "biome lint --write",
    "preview": "vite preview",
    "test": "vitest",
    "test:browser": "vitest --workspace=vitest.workspace.ts",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:update-snapshots": "vitest --update --run",
    "test:watch": "vitest --watch",
    "type-check": "tsc --noEmit"
  },
  "type": "module",
  "version": "1.12.0"
}
